    "faq": {
      "id": "pricing-faq",
      "title": "Pricing questions",
      "description": "Clear limits, plain billing terms, and no hidden access changes.",
      "items": [
        {
          "question": "What is the difference between credits and membership?",
          "answer": "Credits pay for each generation. A recurring membership adds the media, resolution, batch, and active-task access shown in the comparison."
        },
        {
          "question": "What can I create on each membership?",
          "answer": "Starter covers image workflows up to 2K. Pro and Ultra unlock 4K images, video, and music. Ultra allows up to four outputs and four active tasks."
        },
        {
          "question": "What happens if I reach a plan limit?",
          "answer": "Existing work remains available. Start fewer outputs, wait for an active generation to finish, or choose a plan with more capacity."
        },
        {
          "question": "Can I cancel a monthly or annual membership?",
          "answer": "Yes. You can manage or cancel a recurring membership from Billing. Your existing access stays active until the current billing period ends."
        },
        {
          "question": "Do unused credits expire?",
          "answer": "One-time credit packs do not expire. Recurring membership credits follow the active billing period shown in your account."
        }
      ]
    }
