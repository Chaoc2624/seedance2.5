# app
VITE_APP_URL = "http://localhost:3000"
VITE_APP_NAME = "Seedance 2.5"

# preset: 'full' (AI SaaS with admin) or 'lite' (landing page, no admin)
VITE_APP_PRESET = "full"

# theme
VITE_THEME = "default"

# appearance
VITE_APPEARANCE = "light"

# layout
# top: horizontal header at the top
# left: vertical sidebar header on desktop; top menu on mobile
LAYOUT_HEADER_POSITION = "top"

# database
# For a static landing page, set DATABASE_PROVIDER = "none" and leave
# DATABASE_URL empty. DB-backed features such as persisted feedback, auth
# sessions, admin, payments, and database blog posts require a real database.
DATABASE_PROVIDER = "sqlite"
DATABASE_URL = "file:data/local.db"
DB_SCHEMA_FILE = "./src/config/db/schema.sqlite.ts"
DB_MIGRATIONS_OUT = "./src/config/db/migrations_sqlite"
DB_SINGLETON_ENABLED = "true"
DB_MAX_CONNECTIONS = "1"

# auth secret
# openssl rand -base64 32
AUTH_SECRET = ""

# google auth
GOOGLE_AUTH_ENABLED = ""
GOOGLE_ONE_TAP_ENABLED = ""
GOOGLE_CLIENT_ID = ""
GOOGLE_CLIENT_SECRET = ""

# google analytics / search console
GOOGLE_ANALYTICS_ID = ""
GOOGLE_SEARCH_CONSOLE_ID = ""
CLARITY_ID = ""
PLAUSIBLE_SCRIPT_ID = ""
BING_WEBMASTER_VERIFICATION_ID = ""
BING_INDEXNOW_KEY = ""

# ads / consent
ADSENSE_CODE = ""
GOOGLE_FUNDING_CHOICES_ID = ""

# ai providers
# Keep provider keys server-side only. Do not expose them as VITE_* variables.
KIE_API_KEY = ""

# cloudflare deployment
# pages: Cloudflare Pages, worker: Cloudflare Workers
CLOUDFLARE_DEPLOY_TARGET = "pages"
CF_PAGES_PROJECT = "seedance2-5"
CF_PAGES_BRANCH = "main"
CF_WORKER_NAME = "seedance2-5"
CF_WORKER_CUSTOM_DOMAIN = "seedance-2-5.app"
DEPLOY_RUN_SEO_MAPS = "auto"
