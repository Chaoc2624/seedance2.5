# Deployment config for ./deploy.sh. Secrets belong in ignored .env.deploy.
CLOUDFLARE_DEPLOY_TARGET = "worker"
CF_WORKER_NAME = "seedance2-5"
CF_WORKER_ROUTE_PATTERN = "seedance-2-5.app/*"
CF_WORKER_ROUTE_ZONE_NAME = "seedance-2-5.app"
VITE_APP_URL = "https://seedance-2-5.app"
VITE_APP_NAME = "Seedance 2.5"
VITE_APP_PRESET = "full"
VITE_APPEARANCE = "light"
BLOG_STORAGE_MODE = "mdx-db"
VITE_BLOG_STORAGE_MODE = "mdx-db"
DATABASE_PROVIDER = "postgresql"
DB_SCHEMA_FILE = "./src/config/db/schema.postgres.ts"
DB_MIGRATIONS_OUT = "./src/config/db/migrations"
DB_SINGLETON_ENABLED = "true"
DB_MAX_CONNECTIONS = "1"
DEPLOY_RUN_SEO_MAPS = "auto"
CF_WORKER_REQUIRED_VARS = "VITE_APP_URL,DATABASE_URL,AUTH_SECRET"
