{
  "name": "ship-template",
  "version": "1.8.2",
  "type": "module",
  "private": true,
  "bin": {
    "shiponce": "scripts/init/create-project.mjs"
  },
  "imports": {
    "#db/sqlite": {
      "workerd": "./src/core/db/mock-sqlite.server.ts",
      "worker": "./src/core/db/mock-sqlite.server.ts",
      "default": "./src/core/db/sqlite.server.ts"
    }
  },
  "scripts": {
    "generate:indexnow-key": "tsx scripts/seo/generate-indexnow-key.ts",
    "sync-schema": "tsx scripts/with-env.ts bunx tsx scripts/db/sync-schema.ts",
    "predev": "bun run sync-schema --silent && SHIPONCE_INDEXNOW_MODE=development bun run generate:indexnow-key",
    "dev": "vite dev",
    "prebuild": "bun run sync-schema --silent && SHIPONCE_INDEXNOW_MODE=production bun run generate:indexnow-key",
    "build": "vite build",
    "dev:lite": "SHIPONCE_INDEXNOW_MODE=development bun run generate:indexnow-key && VITE_APP_PRESET=lite BLOG_STORAGE_MODE=mdx VITE_BLOG_STORAGE_MODE=mdx vite dev",
    "build:lite": "SHIPONCE_INDEXNOW_MODE=production bun run generate:indexnow-key && VITE_APP_PRESET=lite BLOG_STORAGE_MODE=mdx VITE_BLOG_STORAGE_MODE=mdx vite build",
    "build:cf:pages": "SHIPONCE_INDEXNOW_MODE=production bun run generate:indexnow-key && VITE_APP_PRESET=lite BLOG_STORAGE_MODE=mdx VITE_BLOG_STORAGE_MODE=mdx NITRO_PRESET=cloudflare_pages vite build && node scripts/deploy/patch-cf-runtime.mjs",
    "preview:cf:pages": "bunx wrangler pages dev dist",
    "deploy": "bash ./deploy.sh",
    "build:cf:worker": "SHIPONCE_INDEXNOW_MODE=production bun run generate:indexnow-key && VITE_APP_PRESET=full NITRO_PRESET=cloudflare_module vite build && node scripts/deploy/patch-cf-runtime.mjs",
    "preview:cf:worker": "bunx wrangler dev --config .output/server/wrangler.json",
    "start": "node .output/server/index.mjs",
    "lint": "oxlint src scripts types",
    "lint:fix": "oxlint src scripts types --fix",
    "lint:strict": "oxlint src scripts types -D correctness",
    "format": "oxfmt .oxfmtrc.json .oxlintrc.json package.json scripts/with-env.ts AGENTS.md CLAUDE.md .agents/skills/shiponce src",
    "format:check": "oxfmt --check .oxfmtrc.json .oxlintrc.json package.json scripts/with-env.ts AGENTS.md CLAUDE.md .agents/skills/shiponce src",
    "format:repo": "oxfmt .",
    "format:repo:check": "oxfmt --check .",
    "db:generate": "tsx scripts/with-env.ts bunx drizzle-kit generate --config=src/core/db/config.ts",
    "db:migrate": "tsx scripts/with-env.ts bunx drizzle-kit migrate --config=src/core/db/config.ts",
    "db:push": "tsx scripts/with-env.ts bunx drizzle-kit push --config=src/core/db/config.ts",
    "db:studio": "tsx scripts/with-env.ts bunx drizzle-kit studio --config=src/core/db/config.ts",
    "auth:generate": "tsx scripts/with-env.ts bunx @better-auth/cli generate --config=src/core/auth/index.ts",
    "admin:init": "tsx scripts/with-env.ts bunx tsx scripts/init/init-admin.ts",
    "rbac:init": "tsx scripts/with-env.ts bunx tsx scripts/init/init-rbac.ts",
    "rbac:assign": "tsx scripts/with-env.ts bunx tsx scripts/db/assign-role.ts",
    "localize:ai-mocks": "tsx scripts/with-env.ts bunx tsx scripts/db/localize-ai-mock-images.ts",
    "init": "tsx scripts/init/init-project.ts",
    "create": "node scripts/init/create-project.mjs",
    "landing": "tsx scripts/init/generate-landing.ts"
  },
  "dependencies": {
    "@better-fetch/fetch": "^1.1.18",
    "@bprogress/core": "^1.3.4",
    "@hello-pangea/dnd": "^18.0.1",
    "@hookform/resolvers": "^5.2.1",
    "@libsql/client": "^0.15.9",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@react-email/components": "^1.0.2",
    "@tanstack/react-router": "^1.168.4",
    "@tanstack/react-start": "^1.167.8",
    "@vitejs/plugin-react": "^6.0.1",
    "aws4fetch": "^1.0.20",
    "better-auth": "^1.3.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "creem": "^0.3.37",
    "drizzle-orm": "^0.44.2",
    "embla-carousel-auto-scroll": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.23.12",
    "github-markdown-css": "^5.8.1",
    "gsap": "^3.15.0",
    "h3": "2.0.1-rc.19",
    "i18next": "^25.10.9",
    "lucide-react": "^0.543.0",
    "markdown-it": "^14.1.0",
    "moment": "^2.30.1",
    "mysql2": "^3.16.0",
    "nanoid": "^5.1.6",
    "next-themes": "^0.4.6",
    "nitro": "3.0.260311-beta",
    "overtype": "^1.2.6",
    "postgres": "^3.4.7",
    "react": "19.2.1",
    "react-copy-to-clipboard": "^5.1.0",
    "react-dom": "19.2.1",
    "react-hook-form": "^7.62.0",
    "react-i18next": "^16.6.6",
    "react-use-measure": "^2.1.7",
    "recharts": "2.15.4",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "replicate": "^1.3.1",
    "resend": "^6.0.3",
    "rough-notation": "^0.5.1",
    "simple-flakeid": "^0.0.5",
    "sonner": "^2.0.7",
    "stripe": "^18.5.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "unified": "^11.0.5",
    "uuid": "^13.0.0",
    "vaul": "^1.1.2",
    "vite": "^8.0.3",
    "zod": "^4.1.5",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@clack/prompts": "^1.2.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/bun": "latest",
    "@types/markdown-it": "^14.1.2",
    "@types/mdx": "^2.0.13",
    "@types/node": "^20",
    "@types/react": "19.2.2",
    "@types/react-copy-to-clipboard": "^5.0.7",
    "@types/react-dom": "19.2.2",
    "autoprefixer": "^10.4.21",
    "baseline-browser-mapping": "^2.10.10",
    "click-to-react-component": "^1.1.3",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.4",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "picocolors": "^1.1.1",
    "postcss": "^8.5.6",
    "react-grep": "^0.3.3",
    "tailwindcss": "^4",
    "tsx": "^4.20.3",
    "turndown": "^7.2.4",
    "typescript": "^5",
    "wrangler": "^4.34.0"
  }
}
